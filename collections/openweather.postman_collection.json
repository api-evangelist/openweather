      "item": [
        {
          "id": "2d66047d-3f2c-41ff-a885-76a43340ca1a",
          "name": "Current and forecast weather data for a coordinate",
          "request": {
            "name": "Current and forecast weather data for a coordinate",
            "description": {
              "content": "Returns current weather, minute-by-minute forecast for one hour, hourly forecast for 48 hours, daily forecast for 8 days, and any government weather alerts for the supplied latitude and longitude.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "onecall"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "lat",
                  "value": "<float>",
                  "description": "(Required) Latitude in decimal degrees, range -90 to 90."
                },
                {
                  "disabled": false,
                  "key": "lon",
                  "value": "<float>",
                  "description": "(Required) Longitude in decimal degrees, range -180 to 180."
                },
                {
                  "disabled": false,
                  "key": "exclude",
                  "value": "<string>",
                  "description": "Comma-separated list of forecast blocks to omit from the response. Allowed values are current, minutely, hourly, daily, and alerts."
                },
                {
                  "disabled": false,
                  "key": "units",
                  "value": "<string>",
                  "description": "Units of measurement. One of standard, metric, or imperial. Default is standard (Kelvin, m/s)."
                },
                {
                  "disabled": false,
                  "key": "lang",
                  "value": "<string>",
                  "description": "ISO language code for localized response text."
                },
                {
                  "disabled": false,
                  "key": "appid",
                  "value": "<string>",
                  "description": "(Required) OpenWeather API key."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
